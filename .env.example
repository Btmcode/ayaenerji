# GEMINI_API_KEY: Required for Gemini AI API calls.
# Automatically injects this at runtime from environment variables.
# Configure this via the system settings.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this app is hosted.
# Automatically injects this at runtime with the service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Supabase Configurations
SUPABASE_URL="YOUR_SUPABASE_URL"
SUPABASE_PUBLISHABLE_KEY="YOUR_SUPABASE_PUBLISHABLE_KEY"
SUPABASE_SECRET_KEY="YOUR_SUPABASE_SECRET_KEY"
SUPABASE_JWKS_URL="YOUR_SUPABASE_JWKS_URL"
VITE_SUPABASE_URL="YOUR_SUPABASE_URL"
VITE_SUPABASE_ANON_KEY="YOUR_SUPABASE_PUBLISHABLE_KEY"
