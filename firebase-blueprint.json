        { "name": "status", "type": "string", "required": true },
        { "name": "notes", "type": "string", "required": false },
        { "name": "createdAt", "type": "timestamp", "required": true }
      ],
      "securityRules": {
        "read": "request.auth != null",
        "create": "true",
        "update": "request.auth != null",
        "delete": "request.auth != null"
